<dynamic_object>
    <diesel orientation_object="rp_pex_prop_evidence_shredder" materials="units/pd2_dlc_pex/props/pex_prop_evidence_shredder/pex_prop_evidence_shredder" />
    <sequence_manager file="units/pd2_dlc_pex/props/pex_prop_evidence_shredder/pex_prop_evidence_shredder" />

    <animations>
        <animation_group name="anim_shredder" enabled="false">
            <object name="anim_shredder_01" />
            <object name="anim_shredder_02" />
        </animation_group>
    </animations>

    <bodies>
        <body enabled="true" template="static" name="static_body" >
            <object collision_type="box" name="c_box" padding="-3.5" />
        </body>
    </bodies>

    <decal_surfaces default_material="metal">
        <decal_mesh name="dm_dm" enabled="true" material="metal" />
    </decal_surfaces>

    <graphics>
        <object name="g_g" enabled="true"/>
        <lod_object name="lod_outline">
            <object name="g_outline" enabled="true"  max_distance="400" />
            <object name="g_outline_lod" enabled="true" />
        </lod_object>
        <graphic_group name="grp_document" enabled="false">
            <object name="g_documents_01" enabled="true" />
            <object name="g_documents_02" enabled="true" />
        </graphic_group>
    </graphics>
    
</dynamic_object>
