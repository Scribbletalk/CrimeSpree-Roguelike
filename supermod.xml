<mod>
	<!--
		Asset injection for the FWB-style copy machine prop so it can be spawned
		in any heist/safehouse, not only the ones whose packages happen to index it.

		The .unit is marked dyn_package=true by default (see SuperModAssetLoader
		DYNAMIC_LOAD_TYPES), so it's auto-loaded into packages/dyn_resources at mod
		init. Companion files get DB entries only — the engine chases them via DB
		lookup when the unit is spawned.

		Adding/removing files here requires a game restart.
	-->
	<assets base_path="assets/">
		<!-- Core copy machine unit + dependencies -->
		<file name="units/payday2/props/off_prop_copy_machine_smuggle/off_prop_copy_machine_smuggle.unit"/>
		<file name="units/payday2/props/off_prop_copy_machine_smuggle/off_prop_copy_machine_smuggle.object"/>
		<file name="units/payday2/props/off_prop_copy_machine_smuggle/off_prop_copy_machine_smuggle.model"/>
		<file name="units/payday2/props/off_prop_copy_machine_smuggle/off_prop_copy_machine_smuggle.material_config"/>
		<file name="units/payday2/props/off_prop_copy_machine_smuggle/off_prop_copy_machine_smuggle.cooked_physics"/>
		<file name="units/payday2/props/off_prop_copy_machine_smuggle/off_prop_copy_machine_smuggle.sequence_manager"/>

		<!-- Textures referenced by the material_config -->
		<file name="units/world/props/office/copy_machine/copy_machine_03_df.texture"/>
		<file name="units/equipment/vault_drill/vault_drill_base_nm.texture"/>
		<file name="units/equipment/vault_drill/vault_drill_base_df.texture"/>

		<!-- Scrapper (evidence shredder) prop. Vanilla pex DLC unit, but its
			package is only mounted on Election Day, so we register the files
			here so it can be spawned anywhere. .unit XML is rewritten with
			network sync="none" (sync="spawn" AVs clients, see memory). -->
		<file name="units/pd2_dlc_pex/props/pex_prop_evidence_shredder/pex_prop_evidence_shredder.unit"/>
		<file name="units/pd2_dlc_pex/props/pex_prop_evidence_shredder/pex_prop_evidence_shredder.object"/>
		<file name="units/pd2_dlc_pex/props/pex_prop_evidence_shredder/pex_prop_evidence_shredder.model"/>
		<file name="units/pd2_dlc_pex/props/pex_prop_evidence_shredder/pex_prop_evidence_shredder.material_config"/>
		<file name="units/pd2_dlc_pex/props/pex_prop_evidence_shredder/pex_prop_evidence_shredder.cooked_physics"/>
		<file name="units/pd2_dlc_pex/props/pex_prop_evidence_shredder/pex_prop_evidence_shredder.sequence_manager"/>
		<file name="units/pd2_dlc_pex/props/pex_prop_evidence_shredder/shredder_df.texture"/>
		<file name="units/pd2_dlc_pex/props/pex_prop_evidence_shredder/shredder_nm.texture"/>

		<!-- Familiar Friend arrow VFX. Custom .unit referencing the vanilla ECP
			arrow .object (loaded from the ECP DLC package), but with no
			AmmoClip / ContourExt extensions — prevents the player from being
			able to pick up our VFX arrows and prevents throwable-outline HUDs
			from highlighting them. -->
		<file name="units/payday2_csr/wildcards/ff_arrow/ff_arrow.unit"/>
	</assets>
</mod>
